# Used by docker-compose.test.yml (CI integration tests).
# Single source of truth for CI test environment values.

# Main service (todofy-test)
ALLOWED_USERS=testuser:testpassword
DATABASE_PATH=/tmp/test.db
LLMAddr=todofy-llm:50051
TodoAddr=todofy-todo:50052
DependencyAddr=todofy-todo:50052
TodoistAddr=todofy-todo:50052
DatabaseAddr=todofy-database:50053

# LLM service (todofy-llm-test)
# Get GEMINI_API_KEY:
# - https://ai.google.dev/tutorials/setup
# - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Todo service (todofy-todo-test)
# Get TODOIST_API_KEY:
# - https://www.todoist.com/help/articles/find-your-api-token-Jpzx9IIlB
TODOIST_API_KEY=
# Get TODOIST_DEFAULT_PROJECT_ID and DEPENDENCY_BOOTSTRAP_EXCLUDED_PROJECT_IDS:
# - https://developer.todoist.com/api/v1/ (use the Projects API and read project `id`)
TODOIST_DEFAULT_PROJECT_ID=
# Get TODOIST_WEBHOOK_SECRET (Todoist App Client Secret):
# - https://developer.todoist.com/api/v1/ (App Management Console and webhook signature details)
TODOIST_WEBHOOK_SECRET=
DEPENDENCY_RECONCILE_INTERVAL=30m
DEPENDENCY_WEBHOOK_DEBOUNCE=20s
DEPENDENCY_GRACE_PERIOD=2m
DEPENDENCY_ENABLE_SCHEDULER=true
DEPENDENCY_BOOTSTRAP_EXCLUDED_PROJECT_IDS=
