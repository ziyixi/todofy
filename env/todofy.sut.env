# Used by docker-compose.sut.yml (system-under-test integration tests).

# Main service (todofy-sut)
ALLOWED_USERS=sutuser:sutpassword
DATABASE_PATH=/tmp/sut-bootstrap.db
LLMAddr=todofy-llm-sut:50051
TodoAddr=todofy-todo-sut:50052
DependencyAddr=todofy-todo-sut:50052
TodoistAddr=todofy-todo-sut:50052
DatabaseAddr=todofy-database-sut:50053
RATE_LIMIT_REQUESTS_PER_MINUTE=0

# LLM service (todofy-llm-sut)
GEMINI_API_KEY=sut-gemini-key
GOOGLE_GEMINI_BASE_URL=http://todofy-fake-gemini-sut:8080

# Todo service (todofy-todo-sut)
TODOIST_API_KEY=sut-todoist-token
TODOIST_BASE_URL=http://todofy-fake-todoist-sut:8080/api/v1
# In the Todoist web app, open the project and read the number in the URL after `/project/`.
# Example: `https://app.todoist.com/app/project/2299753711` -> `2299753711`
# You can comma-join multiple project IDs for DEPENDENCY_BOOTSTRAP_EXCLUDED_PROJECT_IDS.
# API fallback:
# - curl -sS -H "Authorization: Bearer $TODOIST_API_KEY" https://api.todoist.com/api/v1/projects
TODOIST_DEFAULT_PROJECT_ID=sut-default-project
TODOIST_WEBHOOK_SECRET=sut-webhook-secret
DEPENDENCY_RECONCILE_INTERVAL=0s
DEPENDENCY_WEBHOOK_DEBOUNCE=0s
DEPENDENCY_GRACE_PERIOD=0s
DEPENDENCY_RECONCILE_TIMEOUT=2s
DEPENDENCY_READ_TIMEOUT=1s
DEPENDENCY_WRITE_TIMEOUT=1s
DEPENDENCY_ENABLE_SCHEDULER=true
DEPENDENCY_BOOTSTRAP_EXCLUDED_PROJECT_IDS=proj-excluded-a,proj-excluded-b
